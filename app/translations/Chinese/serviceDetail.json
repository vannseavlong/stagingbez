  "6": {
    "id": 6,
    "banner": {
      "title": "洗衣机清洁服务",
      "description": "PLACEHOLDER - 请替换服务ID 6的描述。",
      "landscape": "/images/serviceDetail/Washing/Wash_Hero.webp",
      "portrait": "/images/serviceDetail/Washing/Wash_Hero.webp",
      "downloadButton": true
    },
    "taskInfo": {
      "imageSrc": "/images/services/washing.webp",
      "title": "您的清洁任务包括什么？",
      "description": "PLACEHOLDER - 请替换服务ID 6的完整描述。",
      "subtitle": "程序信息"
    },
    "taskList": [
      {
        "title": "准备工作",
        "items": [
          "拔掉洗衣机的电源插头。",
          "关闭两个供水进水阀。",
          "确保滚筒完全清空。",
          "准备以下清洁材料:",
          "洗衣机清洁剂/肥皂",
          "软布或海绵",
          "小刷子或旧牙刷",
          "水桶和毛巾"
        ]
      },
      {
        "title": "清洁洗涤剂抽屉",
        "items": [
          "完全拉出洗涤剂抽屉。",
          "将其浸泡在混合了温和洗涤剂的温水中几分钟。",
          "使用小刷子刷掉残留物或霉菌。",
          "彻底冲洗并完全擦干，然后重新安装抽屉。"
        ]
      },
      {
        "title": "清洁橡胶门封（前置式洗衣机）",
        "items": [
          "打开门，轻轻拉回橡胶密封圈。",
          "使用湿布清除污垢、绒毛和滞留的碎屑。",
          "用温和的清洁溶液或消毒剂擦拭。",
          "用毛巾彻底擦干，以防止霉菌滋生。"
        ]
      },
      {
        "title": "深度清洁滚筒",
        "items": [
          "将洗衣机清洁剂加入洗涤剂托盘或直接加入滚筒。",
          "运行滚筒清洁或桶清洁程序（如果可用）。",
          "如果没有清洁周期，则在滚筒为空的情况下运行热水循环（60-90°C）。"
        ]
      },
      {
        "title": "清洁排水泵过滤器",
        "items": [
          "找到排水泵过滤器（通常在底部前面板）。",
          "在下面放置毛巾或浅盘以接水。",
          "打开过滤器盖，清除绒毛、硬币或碎屑。",
          "用流水冲洗过滤器并牢固地重新安装。"
        ]
      },
      {
        "title": "清洁外部",
        "items": [
          "使用蘸有温和洗涤剂的软布擦拭所有外部表面。",
          "仔细清洁控制面板、盖子、侧面和底部。",
          "避免将水直接喷洒在按钮或通风区域。"
        ]
      },
      {
        "title": "最后步骤",
        "items": [
          "将门打开数小时，让内部完全风干。",
          "重新连接水和电源。",
          "运行一次短时漂洗循环，确保所有清洁剂都已冲洗干净。",
          "在维护日志上记录清洁日期和首字母。"
        ]
      }
    ],
