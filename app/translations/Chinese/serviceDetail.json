      "subtitle": "流程信息"
    },
    "taskList": [
      {
        "title": "准备工作",
        "items": [
          "拔下洗衣机的电源插头。",
          "关闭两个供水入口阀。",
          "确保滚筒完全清空。",
          "准备以下清洁材料：",
          "洗衣机清洁剂/肥皂",
          "软布或海绵",
          "小刷子或旧牙刷",
          "水桶和毛巾"
        ]
      },
      {
        "title": "清洁洗涤剂抽屉",
        "items": [
          "完全拉出洗涤剂抽屉。",
          "将其浸泡在混合了温和洗涤剂的温水中几分钟。",
          "使用小刷子刷掉任何残留物或霉菌。",
          "彻底冲洗并完全干燥后再重新安装抽屉。"
        ]
      },
      {
        "title": "清洁橡胶门密封圈（前置式洗衣机）",
        "items": [
          "打开门并轻轻拉回橡胶密封圈。",
          "使用湿布清除污垢、绒毛和被困的碎屑。",
          "用温和的清洁溶液或消毒剂擦拭。",
          "用毛巾彻底擦干以防止霉菌滋生。"
        ]
      },
      {
        "title": "深度清洁滚筒",
        "items": [
          "将洗衣机清洁剂加入洗涤剂托盘或直接倒入滚筒。",
          "运行滚筒清洁或筒清洁程序（如果可用）。",
          "如果没有清洁周期，请在滚筒清空的情况下运行热水周期（60-90°C）。"
        ]
      },
      {
        "title": "清洁排水泵过滤器",
        "items": [
          "找到排水泵过滤器（通常位于底部前面板）。",
          "在下面放一条毛巾或浅托盘以接住水。",
          "打开过滤器盖，清除绒毛、硬币或碎屑。",
          "在流水下冲洗过滤器并牢固地重新安装。"
        ]
      },
      {
        "title": "清洁外部",
        "items": [
          "使用沾有温和洗涤剂的软布擦拭所有外部表面。",
          "仔细清洁控制面板、盖子、侧面和底部。",
          "避免将水直接喷洒在按钮或通风区域。"
        ]
      },
      {
        "title": "最后步骤",
        "items": [
          "将所有部件正确重新安装。",
          "打开门数小时，让内部完全风干。",
          "重新连接水和电源。",
          "运行一个短冲洗周期以确保所有清洁剂都被冲洗干净。",
          "在维护日志上记录清洁日期和首字母缩写。"
        ]
      }
    ],
